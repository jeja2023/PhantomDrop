# ==========================================
# PhantomDrop (幻影中台) 环境变量模板
# ==========================================

# 运行环境配置 (production / development)
# 生产部署建议设置为 production；此时 HUB_SECRET 不能使用默认值。
APP_ENV=production

# 首次初始化管理员账户时必须提供至少 12 个字符的密码。
# 初始化完成后，凭据以 Argon2id 哈希保存在 SQLite 中，可在系统设置中修改。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 机器密钥（可选）：仅用于 Cloudflare Worker -> Hub /ingest 机器通信。
# 不使用邮件 Worker 时保持为空，/ingest 将以 503 关闭。
# 本地开发可以使用默认值；生产环境必须替换为强随机密钥。
HUB_SECRET=

# 是否开启 Cookie 安全传输 (true / false)
# HTTPS 反向代理部署时设为 true；纯 HTTP 本地访问保持 false。
COOKIE_SECURE=false

# 后端服务监听配置
# BIND_ADDR: 监听的 IP 地址，0.0.0.0 表示监听所有网卡
# PORT: 服务端口号
BIND_ADDR=0.0.0.0
PORT=9010

# 控制台跨域白名单（允许携带认证 Cookie 的来源白名单，多个来源用英文逗号分隔，生产环境不得使用 *）
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:9010,http://localhost:9010

# 调试资源开关 (true / false)
# 开启后会保留运行调试截图，生产环境建议保持 false
ENABLE_DEBUG_ASSETS=false

# OAuth 凭据本地写出开关 (true / false)
# 开启后会将登录凭据写出到本地文件用于调试，生产环境建议保持 false
WRITE_CODEX_AUTH_FILE=false

# 数据库连接配置 (SQLite 数据库连接 URL)
# Docker 环境默认使用 sqlite:///app/data/phantom_core.db?mode=rwc
# 本地直跑测试可改为 sqlite://phantom_core.db?mode=rwc
PHANTOM_DB_URL=sqlite:///app/data/phantom_core.db?mode=rwc

# Cloudflare 自动化配置（可选，也可启动后在 Web 控制台“系统设置”中配置）
# CLOUDFLARE_API_TOKEN: Cloudflare API 令牌
# CLOUDFLARE_ZONE_ID: Cloudflare 区域 ID
# CLOUDFLARE_ACCOUNT_ID: Cloudflare 账户 ID
# CLOUDFLARE_ZONE_DOMAIN: Cloudflare 托管域名
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_DOMAIN=

# OpenAI 网关密钥映射
# 格式为 API密钥=账号池，多个映射用英文逗号分隔，例如: key1=pool1,key2=pool2
PHANTOM_GATEWAY_KEYS=

# 并发控制配置
# MAX_CONCURRENT_WORKFLOWS: 最大并发工作流执行数，默认 2
# MAX_CONCURRENT_PROXY_CHECKS: 最大并发代理检测数，默认 8
MAX_CONCURRENT_WORKFLOWS=2
MAX_CONCURRENT_PROXY_CHECKS=8

# 前端静态资源目录（可选）
# 单镜像模式下通常会自动识别前端资源路径，仅自定义部署需要覆盖时开启
# WEB_DIST=/app/web
