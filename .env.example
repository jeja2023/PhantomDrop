# ==========================================
# PhantomDrop (幻影中台) 环境变量模板
# ==========================================

# 1. 基础安全配置
# 接口令牌请在 Web 控制台“全局设置”中配置；Cloudflare Worker Secret 需与该值一致。
# HUB_SECRET 仅作为无数据库设置时的可选兜底，不建议在 Docker 生产环境配置。

# 生产部署建议设置为 production
APP_ENV=development

# 服务监听配置
BIND_ADDR=0.0.0.0
PORT=9010

# 控制台跨源来源白名单，多个地址用英文逗号分隔
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:9010,http://localhost:9010

# 是否允许访问自动化调试截图；开发环境默认开启，生产环境默认关闭
ENABLE_DEBUG_ASSETS=false

# 是否将 CPA OAuth 凭据额外写入 codex_auth.json 文件
WRITE_CODEX_AUTH_FILE=false

# 2. 数据库配置
# 默认为容器内的 data 目录，建议保持默认以配合数据卷挂载
PHANTOM_DB_URL=sqlite:///app/data/phantom_core.db?mode=rwc

# 3. Cloudflare 自动化配置 (可选)
# 提示: 您也可以在启动后，直接通过 Web 控制台的“系统设置”页面进行图形化配置
# 优先级说明: 环境变量 > Web 界面设置
# 获取地址: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_DOMAIN=

# 4. 其他高级设置 (按需开启)
# 前端资源路径（单镜像模式下自动识别）
# WEB_DIST=/app/web
